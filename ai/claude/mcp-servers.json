{
  "aws": {
    "command": "uvx",
    "args": [
      "awslabs.aws-documentation-mcp-server@latest"
    ],
    "env": {
      "AWS_DOCUMENTATION_PARTITION": "aws",
      "FASTMCP_LOG_LEVEL": "ERROR"
    }
  },
  "context7": {
    "type": "http",
    "url": "https://mcp.context7.com/mcp",
    "headers": {
      "CONTEXT7_API_KEY": "@CONTEXT7_API_KEY@"
    }
  },
  "penpot": {
    "type": "http",
    "url": "https://penpot.iperez.dev/mcp/stream?userToken=@PENPOT_API_KEY@"
  },
  "dbflux": {
    "command": "dbflux",
    "args": [
      "mcp",
      "--client-id",
      "claude"
    ]
  },
  "obsidian": {
    "command": "pnpx",
    "args": [
      "@mauricio.wolff/mcp-obsidian@latest",
      "/home/iperez/Atlas"
    ]
  },
  "atlas": {
    "type": "http",
    "url": "https://atlas.iperez.dev/mcp",
    "headers": {
      "Authorization": "Bearer @ATLAS_TOKEN@"
    }
  },
  "clickup": {
    "command": "npx",
    "args": [
      "-y",
      "mcp-remote",
      "https://mcp.clickup.com/mcp"
    ]
  }
}
