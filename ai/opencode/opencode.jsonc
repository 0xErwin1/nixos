{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@spoons-and-mirrors/subtask2@latest",
    "@warp-dot-dev/opencode-warp",
  ],
  "agent": {
    "sdd-orchestrator": {
      "model": "openai/gpt-5.6-sol",
      "description": "SDD delegate-only orchestrator",
      "mode": "all",
      "prompt": "{file:/home/iperez/.config/opencode/ORCHESTRATOR.md}",
      "tools": {
        "bash": true,
        "delegate": true,
        "delegation_list": true,
        "delegation_read": true,
        "edit": true,
        "fetch": true,
        "glob": true,
        "grep": false,
        "mcp": true,
        "read": true,
        "skill": true,
        "task": true,
        "todoread": true,
        "todowrite": true,
        "webfetch": true,
        "websearch": true,
        "write": true
      }
    },
    "sdd-apply": {
      // "model": "zai-coding-plan/glm-5.1",
      "model": "openai/gpt-5.6-terra",
      // "model": "openai/gpt-5.4",
      "description": "Implement code changes from task definitions",
      "hidden": true,
      "mode": "subagent",
      "prompt": "{file:/home/iperez/.config/opencode/prompts/sdd/sdd-apply.md}",
      "tools": {
        "bash": true,
        "edit": true,
        "fetch": true,
        "glob": true,
        "grep": true,
        "mcp": true,
        "read": true,
        "skill": true,
        "write": true
      }
    },
    "sdd-archive": {
      // "model": "minimax/MiniMax-M2.7",
      "model": "openai/gpt-5.6-luna",
      "description": "Archive completed change artifacts",
      "hidden": true,
      "mode": "subagent",
      "prompt": "{file:/home/iperez/.config/opencode/prompts/sdd/sdd-archive.md}",
      "tools": {
        "bash": true,
        "edit": true,
        "fetch": true,
        "glob": true,
        "grep": true,
        "mcp": true,
        "read": true,
        "skill": true,
        "write": true
      }
    },
    "sdd-design": {
      // "model": "anthropic/claude-opus-4-6",
      // "model": "zai-coding-plan/glm-5.1",
      "model": "openai/gpt-5.6-sol",
      "description": "Create technical design from proposals",
      "hidden": true,
      "mode": "subagent",
      "prompt": "{file:/home/iperez/.config/opencode/prompts/sdd/sdd-design.md}",
      "tools": {
        "bash": true,
        "edit": true,
        "fetch": true,
        "glob": true,
        "grep": true,
        "mcp": true,
        "read": true,
        "skill": true,
        "write": true
      }
    },
    "sdd-explore": {
     // "model": "minimax/MiniMax-M2.7",
      // "model": "zai-coding-plan/glm-5.1",
      "model": "openai/gpt-5.6-terra",
      "description": "Explore codebase and think through ideas",
      "hidden": true,
      "mode": "subagent",
      "prompt": "{file:/home/iperez/.config/opencode/prompts/sdd/sdd-explore.md}",
      "tools": {
        "bash": true,
        "edit": true,
        "fetch": true,
        "glob": true,
        "grep": true,
        "mcp": true,
        "read": true,
        "skill": true,
        "write": true
      }
    },
    "sdd-init": {
      //"model": "minimax/MiniMax-M2.7",
      "model": "openai/gpt-5.6-luna",
      // "model": "zai-coding-plan/glm-5.1",
      "description": "Bootstrap SDD context and project configuration",
      "hidden": true,
      "mode": "subagent",
      "prompt": "{file:/home/iperez/.config/opencode/prompts/sdd/sdd-init.md}",
      "tools": {
        "bash": true,
        "edit": true,
        "fetch": true,
        "glob": true,
        "grep": true,
        "mcp": true,
        "read": true,
        "skill": true,
        "write": true
      }
    },
    "sdd-propose": {
      "model": "openai/gpt-5.6-sol",
      // "model": "minimax/MiniMax-M2.7",
      // "model": "zai-coding-plan/glm-5.1",
      "description": "Create change proposals from explorations",
      "hidden": true,
      "mode": "subagent",
      "prompt": "{file:/home/iperez/.config/opencode/prompts/sdd/sdd-propose.md}",
      "tools": {
        "bash": true,
        "edit": true,
        "fetch": true,
        "glob": true,
        "grep": true,
        "mcp": true,
        "read": true,
        "skill": true,
        "write": true
      }
    },
    "sdd-spec": {
      "model": "openai/gpt-5.6-terra",
      // "model": "zai-coding-plan/glm-5.1",
      "description": "Write detailed specifications from proposals",
      "hidden": true,
      "mode": "subagent",
      "prompt": "{file:/home/iperez/.config/opencode/prompts/sdd/sdd-spec.md}",
      "tools": {
        "bash": true,
        "edit": true,
        "fetch": true,
        "glob": true,
        "grep": true,
        "mcp": true,
        "read": true,
        "skill": true,
        "write": true
      }
    },
    "sdd-tasks": {
      "model": "openai/gpt-5.6-terra",
      // "model": "minimax/MiniMax-M2.7",
      // "model": "zai-coding-plan/glm-5.1",
      "description": "Break down specs and designs into implementation tasks",
      "hidden": true,
      "mode": "subagent",
      "prompt": "{file:/home/iperez/.config/opencode/prompts/sdd/sdd-tasks.md}",
      "tools": {
        "bash": true,
        "edit": true,
        "fetch": true,
        "glob": true,
        "grep": true,
        "mcp": true,
        "read": true,
        "skill": true,
        "write": true
      }
    },
    "sdd-verify": {
      "model": "openai/gpt-5.6-sol",
      // "model": "zai-coding-plan/glm-5.1",
      "description": "Validate implementation against specs",
      "hidden": true,
      "mode": "subagent",
      "prompt": "{file:/home/iperez/.config/opencode/prompts/sdd/sdd-verify.md}",
      "tools": {
        "bash": true,
        "edit": true,
        "fetch": true,
        "glob": true,
        "grep": true,
        "mcp": true,
        "read": true,
        "skill": true,
        "write": true
      }
    }
  },
  "mcp": {
    "aws": {
      "type": "local",
      "enabled": true,
      "command": [
        "uvx",
        "awslabs.aws-documentation-mcp-server@latest"
      ],
      "environment": {
        "AWS_DOCUMENTATION_PARTITION": "aws",
        "FASTMCP_LOG_LEVEL": "ERROR"
      }
    },
    "context7": {
      "type": "remote",
      "enabled": true,
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "@CONTEXT7_API_KEY@"
      }
    },
    "figma": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.figma.com/mcp"
    },
    "penpot": {
      "enabled": true,
      "type": "remote",
      "url": "https://penpot.iperez.dev/mcp/stream?userToken=@PENPOT_API_KEY@"
    },
    "dbflux": {
      "type": "local",
      "command": [
        "dbflux",
        "mcp",
        "--client-id",
        "opencode"
      ]
    },
    "engram": {
      "command": [
        "engram",
        "mcp"
      ],
      "enabled": true,
      "type": "local"
    },
    "obsidian": {
      "type": "local",
      "enabled": true,
      "command":[
        "pnpx",
        "@mauricio.wolff/mcp-obsidian@latest",
        "/home/iperez/Atlas"
      ]
    },
    "atlas": {
      "type": "remote",
      "enabled": true,
      "url": "https://atlas.iperez.dev/mcp",
      "headers": {
        "Authorization": "Bearer @ATLAS_TOKEN@"
      }
    }
  },
  "permission": {
    "bash": {
      "*": "allow",
      "git commit *": "ask",
      "git push": "ask",
      "git push *": "ask",
      "git push --force *": "ask",
      "git rebase *": "ask",
      "git reset --hard *": "ask"
    },
    "external_directory": {
      "~/.config/opencode/**": "allow"
    },
    "read": {
      "*": "allow",
      "**/.env": "deny",
      "**/.env.*": "deny",
      "**/credentials.json": "deny",
      "**/secrets/**": "deny",
      "*.env": "deny",
      "*.env.*": "deny"
    }
  }
}
