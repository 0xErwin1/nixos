#!/usr/bin/env bash

export SCRIPT_PATH="$HOME/.config/leftwm"

if [[ ${DEBUG:-0} == 1 ]]; then
  export THEME_CURRENT="$PWD"
else
  export THEME_CURRENT="$SCRIPT_PATH/themes/current"
fi

SESSION_TAG="${XDG_SESSION_ID:-${DISPLAY//[:.]/_}}"
RUNTIME_DIR="${XDG_RUNTIME_DIR:-/tmp}/leftwm-${SESSION_TAG}"
mkdir -p "$RUNTIME_DIR"

stop_session_proc() {
  local name="$1"
  local pidfile="$RUNTIME_DIR/${name}.pid"

  if [ -f "$pidfile" ]; then
    local pid
    pid="$(cat "$pidfile" 2>/dev/null || true)"
    if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
      kill "$pid" 2>/dev/null || true
    fi
    rm -f "$pidfile"
  fi
}

start_session_proc() {
  local name="$1"
  shift
  local pidfile="$RUNTIME_DIR/${name}.pid"

  if [ -f "$pidfile" ]; then
    local pid
    pid="$(cat "$pidfile" 2>/dev/null || true)"
    if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
      return 0
    fi
  fi

  "$@" >/dev/null 2>&1 &
  echo $! > "$pidfile"
}

if [ -f "$RUNTIME_DIR/theme-down" ]; then
  "$RUNTIME_DIR/theme-down"
  rm -f "$RUNTIME_DIR/theme-down"
fi

ln -sf "$THEME_CURRENT/down" "$RUNTIME_DIR/theme-down"

leftwm-command "LoadTheme $THEME_CURRENT/themes.toml"

start_session_proc eww eww -c "$THEME_CURRENT/eww" daemon

open_bar() {
  eww -c "$THEME_CURRENT/eww" open "$1" >/dev/null 2>&1 || true
}

open_bar laptop

if xrandr | grep -Eq '(^| )DisplayPort-0 connected|(^| )DP-0 connected|(^| )HDMI-A-0 connected|(^| )DP-1-0 connected'; then
  open_bar monitor-DP-0
fi

if xrandr | grep -Eq '(^| )DisplayPort-1 connected|(^| )DP-1 connected|(^| )DP-2 connected'; then
  open_bar monitor-DP-1
fi

if [ -n "$XRDP_SESSION" ] || [ -n "$XRDP_USER" ]; then
  export NO_COMPOSITOR=1
  stop_session_proc picom
else
  start_session_proc picom picom
fi

start_session_proc nm-applet nm-applet
start_session_proc blueman-applet blueman-applet
start_session_proc udiskie udiskie -t
