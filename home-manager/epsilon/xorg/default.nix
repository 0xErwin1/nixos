{ pkgs, ... }:
{
  home = {
    packages = with pkgs; [
      lxsession
      networkmanagerapplet
      blueman
      volumeicon
      redshift
      solaar
      xinput
      xmodmap
      xsetroot
      feh
    ];
  };

  xsession = {
    profileExtra = ''
      xinput set-prop "TPPS/2 Elan TrackPoint" "libinput Accel Speed" -0.6
      xmodmap -e "remove Lock = Caps_Lock"
      xmodmap -e "keycode 66 = Control_L"
      xmodmap -e "add Control = Control_L"
      export XCURSOR_THEME=Bibata-Modern-Classic
      export XCURSOR_SIZE=16
      xsetroot -cursor_name left_ptr

      lxsession &
      nm-applet &
      blueman-adapters &
      battery &
      volumeicon &

      ${pkgs.feh}/bin/feh --bg-fill "~/Wallpapers/man\ near\ Torii\ gate\ wallpaper,\ gray\ temple\ wallpaper,\ landscape.jpg"
    '';
  };

  programs.autorandr = {
    enable = true;

    profiles = {
      mobile = {
        fingerprint = {
          eDP-1 = "";
        };

        config = {
          eDP-1 = {
            enable = true;
            primary = true;
            mode = "1920x1080";
            rate = "60.00";
            position = "0x0";
          };
        };
      };

      dock-dp = {
        fingerprint = {
          eDP-1 = "";
          DP-1-0 = "";
        };

        config = {
          eDP-1 = {
            enable = true;
            primary = true;
            mode = "1920x1080";
            rate = "60.00";
            position = "0x0";
          };

          DP-1-0 = {
            enable = true;
            mode = "1920x1080";
            rate = "60.00";
            position = "0x1080";
          };
        };
      };

      dock-hdmi = {
        fingerprint = {
          eDP-1 = "";

          HDMI-1-0 = "REEMPLAZAR_CON_FINGERPRINT_REAL";
        };

        config = {
          HDMI-1-0 = {
            enable = true;
            primary = true;
            mode = "1920x1080";
            rate = "60.00";
            position = "0x0";
          };

          eDP-1 = {
            enable = true;
            mode = "1920x1080";
            rate = "60.00";
            position = "0x1080";
          };
        };
      };
    };
  };

  xsession.initExtra = ''
    ${pkgs.autorandr}/bin/autorandr --change
  '';
}
