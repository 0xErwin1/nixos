# Fonts
font-family = "JetBrainsMono NerdFont"
font-size = 14
font-style = Regular

# Colors
theme = "Ayu"
# Lighten the theme's near-black background (~#0B0E14) one tone for readability.
# An explicit background set after `theme` overrides the theme's background.
background = 141821

# Window
window-padding-x = 0
window-padding-y = 0
background-opacity = 0.9

# Clipboard
copy-on-select = false

# Shell
shell-integration-features = cursor,no-sudo,title,ssh-env

keybind = shift+enter=text:\x1b\r
