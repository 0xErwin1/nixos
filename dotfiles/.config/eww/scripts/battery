#!/usr/bin/env bash

BATTERY=/sys/class/power_supply/BAT0
PERCENTAGE=$(cat "$BATTERY/capacity")
STATUS="$(cat "$BATTERY/status")"

get_icon() {
  if [[ $STATUS == "Charging" ]]; then
    echo "ÓÄä"
    exit 0
  fi

  case $PERCENTAGE in
    9[0-9]|100)
        echo "ÔČÄ "
      ;;
    8[0-9])
        echo "ÔČĀ "
      ;;
    7[0-9])
        echo "ÔČĀ "
      ;;
    6[0-9])
        echo "ÔČā "
      ;;
    5[0-9])
        echo "ÔČā "
      ;;
    4[0-9])
        echo "ÔČā "
      ;;
    3[0-9])
        echo "ÔČā "
      ;;
    2[0-9])
        echo "ÔČÉ "
        notify-send -r 9991 -u critical "Battery Low: ${PERCENTAGE}%" "Connect Charger"
      ;;
    1[0-9])
        echo "ÔČÉ "
        notify-send -r 9991 -u critical "Battery Low: ${PERCENTAGE}%" "Connect Charger"
      ;;
    [1-9])
        echo "ÔČÉ "
        notify-send -r 9991 -u critical "Battery Low: ${PERCENTAGE}%" "Connect Charger"
      ;;
    *)
        echo "ÔČÉ "
      ;;
  esac
}

if [[ "$1" == "--icon" ]]; then
  get_icon
  exit
elif [[ "$1" == "--percent" ]]; then
  echo "$PERCENTAGE"
  exit
fi
