#!/usr/bin/env bash
set -euo pipefail

HOSTS_FILE="${RDP_HOSTS_FILE:-$HOME/.config/rdp/hosts}"
DEFAULT_USER="${RDP_USER:-$USER}"

prompt_host() {
  rofi -dmenu -p "RDP host" -i
}

resolve_profile() {
  local profile="$1"

  if [[ ! -f "$HOSTS_FILE" ]]; then
    return 1
  fi

  grep -E "^[[:space:]]*${profile}\|" "$HOSTS_FILE" | head -n 1
}

main() {
  local target="${1:-}"
  local user="${2:-$DEFAULT_USER}"
  local profileLine=""
  local host=""
  local extra=""

  if [[ -n "$target" ]]; then
    profileLine="$(resolve_profile "$target" || true)"
  fi

  if [[ -n "$profileLine" ]]; then
    IFS='|' read -r _ host user extra <<<"$profileLine"
    host="${host//[[:space:]]/}"
    user="${user:-$DEFAULT_USER}"
  else
    if [[ -z "$target" ]]; then
      target="$(prompt_host)"
    fi

    host="${target:-}"
  fi

  if [[ -z "$host" ]]; then
    exit 0
  fi

  local -a cmd=(
    xfreerdp
    /v:"$host"
    /u:"$user"
    /f
    /multimon
    /dynamic-resolution
    /clipboard
    /network:auto
    /cert:ignore
    +auto-reconnect
  )

  if [[ -n "${RDP_MONITORS:-}" ]]; then
    cmd+=("/monitors:${RDP_MONITORS}")
  fi

  if [[ -n "$extra" ]]; then
    read -r -a extraArgs <<<"$extra"
    cmd+=("${extraArgs[@]}")
  fi

  exec "${cmd[@]}"
}

main "$@"
